# Copy to .env.prod, fill in strong secrets, and NEVER commit .env.prod.

# ---- Laravel application ----
APP_NAME=*--CHANGE--*
APP_ENV=production
APP_KEY=                                        ### CREATE WITH `php artisan key:generate`
APP_DEBUG=false
APP_URL=http://localhost

# Log to the container's stderr so `docker compose logs` shows them.
LOG_CHANNEL=stderr

# ---- Database: Laravel's names ----
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=*--CHANGE--*
DB_USERNAME=*--CHANGE--*
DB_PASSWORD=*--CHANGE-(STRONG)--*
DB_ROOT_PASSWORD=*--CHANGE-(STRONG)--*

# ---- Database: the MySQL image's names ----
# Same values as above, under the variable names the mysql image reads.
# (Duplicated on purpose — the two programs expect different names.)
MYSQL_DATABASE=*--SAME-AS-DB-DATABSE--*
MYSQL_USER=*--SAME-AS-DB-USERNAME--*
MYSQL_PASSWORD=*--SAME-AS-DB-PASSWORD--*
MYSQL_ROOT_PASSWORD=*--SAME-AS-DB-ROOT-PASSWORD--*

# ---- Safe, low-dependency production defaults ----
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
